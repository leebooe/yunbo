PUBLIC_SITE_URL=https://your-domain.com

# Optional: sync real posts from a private repository during local build or CI.
YUNBO_CONTENT_REPO=git@github.com:your-name/yunbo-content.git
YUNBO_CONTENT_REF=main
YUNBO_CONTENT_DIR=.content-private/repo

# Optional: import local WeChat/Obsidian Markdown.
WECHAT_SOURCE_DIR=/absolute/path/to/wechat-markdown
WECHAT_ATTACHMENTS_DIRS=/absolute/path/to/attachments:/absolute/path/to/images
