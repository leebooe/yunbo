---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const siteName = "Yunbo";
const { title = siteName, description = "A quiet Astro blog theme for thoughtful writing." } = Astro.props;
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const searchQuery = Astro.url.searchParams.get("q") || "";
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="image" href="/images/tech-hero-1280.jpg" fetchpriority="high" />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        const allowed = new Set(["light", "dark", "system"]);
        const allowedWallpaperModes = new Set(["solid", "full-transparent", "full-wallpaper", "banner-wallpaper"]);
        const allowedPostListLayouts = new Set(["grid", "list"]);
        const defaultAccentHue = "47";
        const setAccentHue = (hue) => {
          const numericHue = Number(hue);
          const nextHue = Number.isFinite(numericHue) ? Math.min(360, Math.max(0, numericHue)) : Number(defaultAccentHue);
          document.documentElement.style.setProperty("--accent-hue", String(nextHue));
        };
        let saved = "system";
        let savedAccentHue = defaultAccentHue;
        let savedWallpaperMode = "solid";
        let savedPostListLayout = "grid";
        try {
          saved = localStorage.getItem("yunbo-theme") || "system";
          savedAccentHue = localStorage.getItem("yunbo-accent-hue") || defaultAccentHue;
          savedWallpaperMode = localStorage.getItem("yunbo-wallpaper-mode") || "solid";
          savedPostListLayout = localStorage.getItem("yunbo-post-list-layout") || "grid";
        } catch {}
        document.documentElement.dataset.themeMode = allowed.has(saved) ? saved : "system";
        document.documentElement.dataset.wallpaperMode = allowedWallpaperModes.has(savedWallpaperMode) ? savedWallpaperMode : "solid";
        document.documentElement.dataset.postListLayout = allowedPostListLayouts.has(savedPostListLayout) ? savedPostListLayout : "grid";
        setAccentHue(savedAccentHue);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="container nav" aria-label="主导航">
        <a class="brand" href="/" aria-label="Yunbo 首页">
          <span>Yun</span>
          <strong>bo</strong>
        </a>
        <div class="nav-links">
          <a href="/">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3 11.5 12 4l9 7.5" />
              <path d="M5.5 10.5V20h13v-9.5" />
              <path d="M9.5 20v-5h5v5" />
            </svg>
            <span>首页</span>
          </a>
          <a href="/blog/">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 4h10l4 4v12H5z" />
              <path d="M15 4v5h5" />
              <path d="M8 13h8M8 17h6" />
            </svg>
            <span>文章</span>
          </a>
          <a href="/topics/">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 6h7l2 2h7v10H4z" />
              <path d="M4 10h16" />
            </svg>
            <span>专题</span>
          </a>
          <a href="/archive/">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 4h14v16H5z" />
              <path d="M8 8h8M8 12h8M8 16h5" />
            </svg>
            <span>归档</span>
          </a>
          <a href="/rss.xml">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 5a14 14 0 0 1 14 14" />
              <path d="M5 11a8 8 0 0 1 8 8" />
              <circle cx="6" cy="18" r="1.5" />
            </svg>
            <span>RSS</span>
          </a>
        </div>
        <div class="nav-tools">
          <form class="nav-search" action="/search/" method="get" role="search">
            <label class="sr-only" for="site-search">搜索文章</label>
            <input id="site-search" name="q" type="search" placeholder="搜索文章" autocomplete="off" value={searchQuery} />
            <button type="submit">搜索</button>
          </form>
          <div class="theme-menu">
            <button class="theme-trigger" type="button" aria-label="外观设置" aria-haspopup="true">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 6h10" />
                <path d="M18 6h2" />
                <circle cx="16" cy="6" r="2" />
                <path d="M4 12h3" />
                <path d="M11 12h9" />
                <circle cx="9" cy="12" r="2" />
                <path d="M4 18h11" />
                <path d="M19 18h1" />
                <circle cx="17" cy="18" r="2" />
              </svg>
            </button>
            <div class="theme-popover" aria-label="外观设置">
              <section class="theme-section" aria-label="模式">
                <span class="theme-section-title">模式</span>
                <button type="button" data-theme-mode="light" aria-label="亮色模式">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="12" cy="12" r="4" />
                    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
                  </svg>
                  <span>亮色</span>
                </button>
                <button type="button" data-theme-mode="dark" aria-label="暗色模式">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20 14.5A7.6 7.6 0 0 1 9.5 4a8 8 0 1 0 10.5 10.5Z" />
                  </svg>
                  <span>暗色</span>
                </button>
                <button type="button" data-theme-mode="system" aria-label="跟随系统">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="12" rx="2" />
                    <path d="M8 20h8M12 16v4" />
                  </svg>
                  <span>系统</span>
                </button>
              </section>
              <section class="theme-section theme-accent" aria-label="主题色">
                <div class="theme-section-title theme-accent-title">主题色 <output id="theme-accent-value" for="theme-accent-range">47°</output></div>
                <input id="theme-accent-range" type="range" min="0" max="360" step="1" value="47" />
                <button class="theme-reset" type="button" data-theme-reset aria-label="恢复默认主题色">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M4 12a8 8 0 1 0 2.35-5.65" />
                    <path d="M4 4v6h6" />
                  </svg>
                  <span>恢复默认</span>
                </button>
              </section>
              <section class="theme-section wallpaper-section" aria-label="壁纸模式">
                <div class="theme-section-title">壁纸模式</div>
                <button type="button" data-wallpaper-mode="solid" aria-label="纯色背景">
                  <span class="wallpaper-swatch solid" aria-hidden="true"></span>
                  <span>纯色背景</span>
                </button>
                <button type="button" data-wallpaper-mode="full-transparent" aria-label="全屏透明">
                  <span class="wallpaper-swatch full-transparent" aria-hidden="true"></span>
                  <span>全屏透明</span>
                </button>
                <button type="button" data-wallpaper-mode="full-wallpaper" aria-label="全屏壁纸">
                  <span class="wallpaper-swatch full-wallpaper" aria-hidden="true"></span>
                  <span>全屏壁纸</span>
                </button>
                <button type="button" data-wallpaper-mode="banner-wallpaper" aria-label="横幅壁纸">
                  <span class="wallpaper-swatch banner-wallpaper" aria-hidden="true"></span>
                  <span>横幅壁纸</span>
                </button>
              </section>
              <section class="theme-section list-layout-section" aria-label="文章列表展示">
                <div class="theme-section-title">文章列表</div>
                <button type="button" data-post-list-layout="grid" aria-label="网格展示">
                  <span>网格</span>
                </button>
                <button type="button" data-post-list-layout="list" aria-label="列表展示">
                  <span>列表</span>
                </button>
              </section>
            </div>
          </div>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="container footer-inner">
        <div>
          <span>Yunbo</span>
          <p>用 Markdown 写作，用静态博客沉淀长期思考。</p>
        </div>
        <div class="footer-meta">
          <p class="site-stats" aria-label="站点访问统计">
            <span id="busuanzi_container_site_pv">访问 <strong id="busuanzi_value_site_pv">--</strong> 次</span>
            <span id="busuanzi_container_site_uv">访客 <strong id="busuanzi_value_site_uv">--</strong> 人</span>
          </p>
          <div class="footer-links">
            <p class="footer-copyright">© {currentYear} Yunbo. All rights reserved.</p>
            <a class="footer-github" href="https://github.com/leebooe/yunbo" target="_blank" rel="noreferrer" aria-label="GitHub 仓库">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.18-3.37-1.18-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.82.09-.65.35-1.08.63-1.33-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.6 9.6 0 0 1 12 6c.85 0 1.7.11 2.5.33 1.9-1.29 2.74-1.02 2.74-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2Z" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </footer>
    <script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
    <script is:inline>
      const siteSearch = document.querySelector("#site-search");
      const query = new URLSearchParams(window.location.search).get("q");
      if (siteSearch && query) siteSearch.value = query;

      const root = document.documentElement;
      const themeButtons = document.querySelectorAll("[data-theme-mode]");
      const wallpaperButtons = document.querySelectorAll("[data-wallpaper-mode]");
      const postListLayoutButtons = document.querySelectorAll("[data-post-list-layout]");
      const accentRange = document.querySelector("#theme-accent-range");
      const accentOutput = document.querySelector("#theme-accent-value");
      const accentReset = document.querySelector("[data-theme-reset]");
      const allowedThemes = new Set(["light", "dark", "system"]);
      const allowedWallpaperModes = new Set(["solid", "full-transparent", "full-wallpaper", "banner-wallpaper"]);
      const allowedPostListLayouts = new Set(["grid", "list"]);
      const defaultAccentHue = 47;
      const setThemeMode = (mode) => {
        const nextMode = allowedThemes.has(mode) ? mode : "system";
        root.dataset.themeMode = nextMode;
        try {
          localStorage.setItem("yunbo-theme", nextMode);
        } catch {}
        themeButtons.forEach((button) => {
          button.setAttribute("aria-pressed", String(button.dataset.themeMode === nextMode));
        });
      };
      const setWallpaperMode = (mode) => {
        const nextMode = allowedWallpaperModes.has(mode) ? mode : "solid";
        root.dataset.wallpaperMode = nextMode;
        try {
          localStorage.setItem("yunbo-wallpaper-mode", nextMode);
        } catch {}
        wallpaperButtons.forEach((button) => {
          button.setAttribute("aria-pressed", String(button.dataset.wallpaperMode === nextMode));
        });
      };
      const setPostListLayout = (layout) => {
        const nextLayout = allowedPostListLayouts.has(layout) ? layout : "grid";
        root.dataset.postListLayout = nextLayout;
        try {
          localStorage.setItem("yunbo-post-list-layout", nextLayout);
        } catch {}
        postListLayoutButtons.forEach((button) => {
          button.setAttribute("aria-pressed", String(button.dataset.postListLayout === nextLayout));
        });
      };
      const normalizeHue = (hue) => {
        const numericHue = Number(hue);
        return Number.isFinite(numericHue) ? Math.min(360, Math.max(0, Math.round(numericHue))) : defaultAccentHue;
      };
      const setAccentHue = (hue, shouldSave = true) => {
        const nextHue = normalizeHue(hue);
        root.style.setProperty("--accent-hue", String(nextHue));
        if (accentRange) accentRange.value = String(nextHue);
        if (accentOutput) accentOutput.textContent = `${nextHue}°`;
        if (shouldSave) {
          try {
            localStorage.setItem("yunbo-accent-hue", String(nextHue));
          } catch {}
        }
      };
      const resetAccentHue = () => {
        setAccentHue(defaultAccentHue, false);
        try {
          localStorage.removeItem("yunbo-accent-hue");
        } catch {}
      };

      themeButtons.forEach((button) => {
        button.addEventListener("click", () => setThemeMode(button.dataset.themeMode));
      });
      wallpaperButtons.forEach((button) => {
        button.addEventListener("click", () => setWallpaperMode(button.dataset.wallpaperMode));
      });
      postListLayoutButtons.forEach((button) => {
        button.addEventListener("click", () => setPostListLayout(button.dataset.postListLayout));
      });
      accentRange?.addEventListener("input", () => setAccentHue(accentRange.value));
      accentReset?.addEventListener("click", resetAccentHue);
      setThemeMode(root.dataset.themeMode || "system");
      setWallpaperMode(root.dataset.wallpaperMode || "solid");
      setPostListLayout(root.dataset.postListLayout || "grid");
      try {
        setAccentHue(localStorage.getItem("yunbo-accent-hue") || defaultAccentHue, false);
      } catch {
        setAccentHue(defaultAccentHue, false);
      }
    </script>
  </body>
</html>
