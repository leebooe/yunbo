---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
};

const siteName = "Yunbo";
const { title = siteName, description = "A quiet Astro blog theme for thoughtful writing." } = Astro.props;
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const searchQuery = Astro.url.searchParams.get("q") || "";
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="image" href="/images/tech-hero-1280.jpg" fetchpriority="high" />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        const allowed = new Set(["light", "dark", "system"]);
        const defaultAccentHue = "47";
        const setAccentHue = (hue) => {
          const numericHue = Number(hue);
          const nextHue = Number.isFinite(numericHue) ? Math.min(360, Math.max(0, numericHue)) : Number(defaultAccentHue);
          document.documentElement.style.setProperty("--accent-hue", String(nextHue));
        };
        let saved = "system";
        let savedAccentHue = defaultAccentHue;
        try {
          saved = localStorage.getItem("yunbo-theme") || "system";
          savedAccentHue = localStorage.getItem("yunbo-accent-hue") || defaultAccentHue;
        } catch {}
        document.documentElement.dataset.themeMode = allowed.has(saved) ? saved : "system";
        setAccentHue(savedAccentHue);
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="container nav" aria-label="主导航">
        <a class="brand" href="/" aria-label="Yunbo 首页">
          <span>Yun</span>
          <strong>bo</strong>
        </a>
        <div class="nav-links">
          <a href="/">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3 11.5 12 4l9 7.5" />
              <path d="M5.5 10.5V20h13v-9.5" />
              <path d="M9.5 20v-5h5v5" />
            </svg>
            <span>首页</span>
          </a>
          <a href="/blog/">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 4h10l4 4v12H5z" />
              <path d="M15 4v5h5" />
              <path d="M8 13h8M8 17h6" />
            </svg>
            <span>文章</span>
          </a>
          <a href="/topics/">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M4 6h7l2 2h7v10H4z" />
              <path d="M4 10h16" />
            </svg>
            <span>专题</span>
          </a>
          <a href="/rss.xml">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 5a14 14 0 0 1 14 14" />
              <path d="M5 11a8 8 0 0 1 8 8" />
              <circle cx="6" cy="18" r="1.5" />
            </svg>
            <span>RSS</span>
          </a>
        </div>
        <div class="nav-tools">
          <form class="nav-search" action="/search/" method="get" role="search">
            <label class="sr-only" for="site-search">搜索文章</label>
            <input id="site-search" name="q" type="search" placeholder="搜索文章" autocomplete="off" value={searchQuery} />
            <button type="submit">搜索</button>
          </form>
          <div class="theme-menu">
            <button class="theme-trigger" type="button" aria-label="外观设置" aria-haspopup="true">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 6h10" />
                <path d="M18 6h2" />
                <circle cx="16" cy="6" r="2" />
                <path d="M4 12h3" />
                <path d="M11 12h9" />
                <circle cx="9" cy="12" r="2" />
                <path d="M4 18h11" />
                <path d="M19 18h1" />
                <circle cx="17" cy="18" r="2" />
              </svg>
            </button>
            <div class="theme-popover" aria-label="外观设置">
              <section class="theme-section" aria-label="模式">
                <span class="theme-section-title">模式</span>
                <button type="button" data-theme-mode="light" aria-label="亮色模式">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="12" cy="12" r="4" />
                    <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
                  </svg>
                  <span>亮色</span>
                </button>
                <button type="button" data-theme-mode="dark" aria-label="暗色模式">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20 14.5A7.6 7.6 0 0 1 9.5 4a8 8 0 1 0 10.5 10.5Z" />
                  </svg>
                  <span>暗色</span>
                </button>
                <button type="button" data-theme-mode="system" aria-label="跟随系统">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="3" y="4" width="18" height="12" rx="2" />
                    <path d="M8 20h8M12 16v4" />
                  </svg>
                  <span>系统</span>
                </button>
              </section>
              <section class="theme-section theme-accent" aria-label="主题色">
                <div class="theme-section-title">主题色</div>
                <label for="theme-accent-range">
                  <span>色相</span>
                  <output id="theme-accent-value" for="theme-accent-range">47°</output>
                </label>
                <input id="theme-accent-range" type="range" min="0" max="360" step="1" value="47" />
              </section>
              <button class="theme-reset" type="button" data-theme-reset aria-label="恢复默认主题色">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M4 12a8 8 0 1 0 2.35-5.65" />
                  <path d="M4 4v6h6" />
                </svg>
                <span>恢复默认</span>
              </button>
            </div>
          </div>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="container footer-inner">
        <div>
          <span>Yunbo</span>
          <p>用 Markdown 写作，用静态博客沉淀长期思考。</p>
        </div>
        <div class="footer-meta">
          <p class="site-stats" aria-label="站点访问统计">
            <span id="busuanzi_container_site_pv">访问 <strong id="busuanzi_value_site_pv">--</strong> 次</span>
            <span id="busuanzi_container_site_uv">访客 <strong id="busuanzi_value_site_uv">--</strong> 人</span>
          </p>
          <p class="footer-copyright">© {currentYear} Yunbo. All rights reserved.</p>
        </div>
      </div>
    </footer>
    <script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
    <script is:inline>
      const siteSearch = document.querySelector("#site-search");
      const query = new URLSearchParams(window.location.search).get("q");
      if (siteSearch && query) siteSearch.value = query;

      const root = document.documentElement;
      const themeButtons = document.querySelectorAll("[data-theme-mode]");
      const accentRange = document.querySelector("#theme-accent-range");
      const accentOutput = document.querySelector("#theme-accent-value");
      const accentReset = document.querySelector("[data-theme-reset]");
      const allowedThemes = new Set(["light", "dark", "system"]);
      const defaultAccentHue = 47;
      const setThemeMode = (mode) => {
        const nextMode = allowedThemes.has(mode) ? mode : "system";
        root.dataset.themeMode = nextMode;
        try {
          localStorage.setItem("yunbo-theme", nextMode);
        } catch {}
        themeButtons.forEach((button) => {
          button.setAttribute("aria-pressed", String(button.dataset.themeMode === nextMode));
        });
      };
      const normalizeHue = (hue) => {
        const numericHue = Number(hue);
        return Number.isFinite(numericHue) ? Math.min(360, Math.max(0, Math.round(numericHue))) : defaultAccentHue;
      };
      const setAccentHue = (hue, shouldSave = true) => {
        const nextHue = normalizeHue(hue);
        root.style.setProperty("--accent-hue", String(nextHue));
        if (accentRange) accentRange.value = String(nextHue);
        if (accentOutput) accentOutput.textContent = `${nextHue}°`;
        if (shouldSave) {
          try {
            localStorage.setItem("yunbo-accent-hue", String(nextHue));
          } catch {}
        }
      };
      const resetAccentHue = () => {
        setAccentHue(defaultAccentHue, false);
        try {
          localStorage.removeItem("yunbo-accent-hue");
        } catch {}
      };

      themeButtons.forEach((button) => {
        button.addEventListener("click", () => setThemeMode(button.dataset.themeMode));
      });
      accentRange?.addEventListener("input", () => setAccentHue(accentRange.value));
      accentReset?.addEventListener("click", resetAccentHue);
      setThemeMode(root.dataset.themeMode || "system");
      try {
        setAccentHue(localStorage.getItem("yunbo-accent-hue") || defaultAccentHue, false);
      } catch {
        setAccentHue(defaultAccentHue, false);
      }
    </script>
  </body>
</html>
