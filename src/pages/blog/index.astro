---
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { getAllPosts, getTopics } from "@/lib/posts";

const posts = getAllPosts();
const topics = getTopics(posts);
const tags = [...new Map(posts.flatMap((post) => post.tags).map((tag) => [tag, 0]))].map(([tag]) => ({
  name: tag,
  count: posts.filter((post) => post.tags.includes(tag)).length
})).sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));
const filterData = posts.map((post) => ({
  slug: post.slug,
  title: post.title,
  series: post.series,
  tags: post.tags,
  date: post.date.toISOString(),
  minutes: post.minutes
}));
---

<BaseLayout title="文章">
  <section class="container page-hero compact hero-art article-library-hero">
    <p class="eyebrow">Article library</p>
    <h1>文章</h1>
    <p>按时间整理的 AI 工具、Agent、自动化与 NAS 实战记录。</p>
  </section>
  <section class="container section">
    <div class="blog-controls" data-blog-controls>
      <div class="controls-head">
        <div>
          <span>快速筛选</span>
          <small data-filter-count>{posts.length} 篇文章</small>
        </div>
        <button class="filter-toggle" type="button" data-filter-toggle aria-expanded="false" aria-controls="blog-filter-panel">
          <span data-filter-toggle-label>展开</span>
          <Icon name="lucide:chevron-down" aria-hidden="true" />
        </button>
      </div>
      <div class="filter-panel" id="blog-filter-panel" data-filter-panel>
        <div class="control-row">
          <span>专题</span>
          <div class="filter-pills" data-filter-group="series">
            <button type="button" data-filter-value="all" aria-pressed="true">全部</button>
            {topics.map((topic) => <button type="button" data-filter-value={topic.name}>{topic.name}<b>{topic.count}</b></button>)}
          </div>
        </div>
        <div class="control-row">
          <span>标签</span>
          <div class="filter-pills" data-filter-group="tag">
            <button type="button" data-filter-value="all" aria-pressed="true">全部</button>
            {tags.map((tag) => <button type="button" data-filter-value={tag.name}>{tag.name}<b>{tag.count}</b></button>)}
          </div>
        </div>
        <div class="control-row sort-row">
          <label for="blog-sort">排序</label>
          <div class="sort-controls">
            <div class="sort-pills" data-sort-pills aria-label="排序方式">
              <button type="button" data-sort-value="newest" aria-pressed="true">最新</button>
              <button type="button" data-sort-value="oldest">最早</button>
              <button type="button" data-sort-value="read-asc">短读</button>
              <button type="button" data-sort-value="read-desc">长读</button>
              <button type="button" data-sort-value="title">标题</button>
            </div>
            <select id="blog-sort" data-blog-sort>
              <option value="newest">最新优先</option>
              <option value="oldest">最早优先</option>
              <option value="read-asc">阅读时间短</option>
              <option value="read-desc">阅读时间长</option>
              <option value="title">标题 A-Z</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <div class="post-grid" data-post-grid>
      {posts.map((post) => <PostCard post={post} />)}
    </div>
    <p class="filter-empty" data-filter-empty hidden>没有匹配文章。</p>
    <button class="back-to-top" type="button" data-back-to-top aria-label="回到顶部">
      <Icon name="lucide:arrow-up" aria-hidden="true" />
      <span>顶部</span>
    </button>
    <script id="blog-filter-data" type="application/json" set:html={JSON.stringify(filterData)}></script>
    <script is:inline>
      const posts = JSON.parse(document.querySelector("#blog-filter-data").textContent);
      const controls = document.querySelector("[data-blog-controls]");
      const cards = [...document.querySelectorAll("[data-post-slug]")];
      const count = document.querySelector("[data-filter-count]");
      const empty = document.querySelector("[data-filter-empty]");
      const sortSelect = document.querySelector("[data-blog-sort]");
      const sortButtons = document.querySelectorAll("[data-sort-value]");
      const backToTop = document.querySelector("[data-back-to-top]");
      const filterPanel = document.querySelector("[data-filter-panel]");
      const filterToggle = document.querySelector("[data-filter-toggle]");
      const filterToggleLabel = document.querySelector("[data-filter-toggle-label]");
      const validOptions = {
        series: new Set(["all", ...posts.map((post) => post.series)]),
        tag: new Set(["all", ...posts.flatMap((post) => post.tags)]),
        sort: new Set(["newest", "oldest", "read-asc", "read-desc", "title"])
      };
      const state = {
        series: "all",
        tag: "all",
        sort: "newest"
      };

      const params = new URLSearchParams(window.location.search);
      const normalizeFilterValue = (key, value) => {
        const nextValue = value?.trim() || "all";
        return validOptions[key].has(nextValue) ? nextValue : "all";
      };
      state.series = normalizeFilterValue("series", params.get("series") || params.get("topic"));
      state.tag = normalizeFilterValue("tag", params.get("tag"));
      state.sort = normalizeFilterValue("sort", params.get("sort"));
      const hasActiveFilter = () => state.series !== "all" || state.tag !== "all" || state.sort !== "newest";

      const setFilterPanelOpen = (isOpen) => {
        controls.classList.toggle("is-open", isOpen);
        filterToggle?.setAttribute("aria-expanded", String(isOpen));
        if (filterToggleLabel) filterToggleLabel.textContent = isOpen ? "收起" : "筛选";
      };

      setFilterPanelOpen(hasActiveFilter());
      filterToggle?.addEventListener("click", () => {
        setFilterPanelOpen(!controls.classList.contains("is-open"));
      });

      const setCardVisible = (card, visible, order) => {
        card.hidden = !visible;
        card.setAttribute("aria-hidden", String(!visible));
        card.style.display = visible ? "" : "none";
        if (visible) {
          card.style.order = String(order);
        } else {
          card.style.removeProperty("order");
        }
      }

      const updateBackToTop = () => {
        backToTop?.classList.toggle("is-visible", window.scrollY > 520);
      };

      backToTop?.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
      window.addEventListener("scroll", updateBackToTop, { passive: true });
      updateBackToTop();

      const updateButtons = () => {
        controls.querySelectorAll("[data-filter-group]").forEach((group) => {
          const key = group.dataset.filterGroup;
          group.querySelectorAll("button").forEach((button) => {
            button.setAttribute("aria-pressed", String(button.dataset.filterValue === state[key]));
          });
        });
        sortSelect.value = state.sort;
        sortButtons.forEach((button) => {
          button.setAttribute("aria-pressed", String(button.dataset.sortValue === state.sort));
        });
      };

      const sortPosts = (items) => [...items].sort((a, b) => {
        if (state.sort === "oldest") return new Date(a.date) - new Date(b.date);
        if (state.sort === "read-asc") return a.minutes - b.minutes;
        if (state.sort === "read-desc") return b.minutes - a.minutes;
        if (state.sort === "title") return a.title.localeCompare(b.title);
        return new Date(b.date) - new Date(a.date);
      });

      const syncUrl = () => {
        const next = new URLSearchParams();
        if (state.series !== "all") next.set("series", state.series);
        if (state.tag !== "all") next.set("tag", state.tag);
        if (state.sort !== "newest") next.set("sort", state.sort);
        const query = next.toString();
        window.history.replaceState(null, "", query ? `/blog/?${query}` : "/blog/");
      };

      const render = () => {
        const matched = sortPosts(posts.filter((post) => {
          const seriesMatch = state.series === "all" || post.series === state.series;
          const tagMatch = state.tag === "all" || post.tags.includes(state.tag);
          return seriesMatch && tagMatch;
        }));

        const order = new Map(matched.map((post, index) => [post.slug, index]));
        cards.forEach((card) => {
          const index = order.get(card.dataset.postSlug);
          setCardVisible(card, index !== undefined, index);
        });
        count.textContent = `${matched.length} 篇文章`;
        empty.hidden = matched.length > 0;
        updateButtons();
        syncUrl();
      };

      controls.addEventListener("click", (event) => {
        const button = event.target.closest("[data-filter-value]");
        if (!button) return;
        const group = button.closest("[data-filter-group]");
        const key = group.dataset.filterGroup;
        state[key] = normalizeFilterValue(key, button.dataset.filterValue);
        render();
      });

      sortSelect.addEventListener("change", () => {
        state.sort = normalizeFilterValue("sort", sortSelect.value);
        render();
      });

      sortButtons.forEach((button) => {
        button.addEventListener("click", () => {
          state.sort = normalizeFilterValue("sort", button.dataset.sortValue);
          render();
        });
      });

      render();
    </script>
  </section>
</BaseLayout>
