---
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate, getAllPosts, getBlogFilterUrl } from "@/lib/posts";

export function getStaticPaths() {
  return getAllPosts().map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const Content = post.entry.default;
const allPosts = getAllPosts();
const seriesPosts = allPosts.filter((item) => item.series === post.series);
const currentIndex = seriesPosts.findIndex((item) => item.slug === post.slug);
const prevPost = currentIndex > 0 ? seriesPosts[currentIndex - 1] : undefined;
const nextPost = currentIndex >= 0 ? seriesPosts[currentIndex + 1] : undefined;
const recommendedPosts = allPosts
  .filter((item) => item.slug !== post.slug)
  .map((item) => ({
    post: item,
    score: (item.series === post.series ? 2 : 0) + item.tags.filter((tag) => post.tags.includes(tag)).length
  }))
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score || b.post.date.getTime() - a.post.date.getTime())
  .slice(0, 3);
const githubUrl = "https://github.com/leebooe/yunbo";
const codeBlockMode = process.env.YUNBO_CODE_BLOCKS === "expressive" ? "expressive" : "legacy";
---

<BaseLayout title={post.title} description={post.description}>
  <article data-pagefind-body>
    <header class="article-header article-detail-hero">
      <div class="article-header-main">
        <div class="meta">
          <span>{formatDate(post.date)}</span>
          <a href={getBlogFilterUrl({ series: post.series })}>{post.series}</a>
          <span>约 {post.minutes} 分钟阅读</span>
        </div>
        <h1>{post.title}</h1>
        <div class="tag-list" aria-label="标签">
          {post.tags.map((tag) => <a class="tag" href={getBlogFilterUrl({ tag })}>{tag}</a>)}
        </div>
      </div>
    </header>
    <div class="article-shell">
      <div class="article-body">
        <Content />
      </div>
      <button class="toc-toggle" type="button" data-toc-toggle aria-expanded="false" aria-controls="article-toc" hidden>目录</button>
      <aside class="article-side">
        <section class="article-toc" id="article-toc" aria-label="文章目录" data-article-toc hidden>
          <h2>目录</h2>
          <nav></nav>
        </section>
        {recommendedPosts.length > 0 && (
          <section class="article-recommendations" aria-label="智能推荐">
            <h2>智能推荐</h2>
            {recommendedPosts.map(({ post: item }) => (
              <a href={item.url}>
                <strong>{item.title}</strong>
                <span>{item.series} · {formatDate(item.date)}</span>
              </a>
            ))}
          </section>
        )}
      </aside>
      <section class="article-cta" aria-label="订阅更新">
        <div>
          <p class="eyebrow">Keep reading</p>
          <h2>订阅后续更新</h2>
          <p>用 RSS 跟进新文章，或者到 GitHub 查看主题源码。</p>
        </div>
        <div>
          <a class="button primary" href="/rss.xml">RSS 订阅</a>
          <a class="button secondary" href={githubUrl} target="_blank" rel="noreferrer">GitHub</a>
        </div>
      </section>
    </div>
    {(prevPost || nextPost) && (
      <nav class="series-nav" aria-label="同系列文章">
        <a class="series-nav-title" href={getBlogFilterUrl({ series: post.series })}>{post.series}</a>
        <div>
          {prevPost && (
            <a href={prevPost.url}>
              <span>上一篇</span>
              <strong>{prevPost.title}</strong>
            </a>
          )}
          {nextPost && (
            <a href={nextPost.url}>
              <span>下一篇</span>
              <strong>{nextPost.title}</strong>
            </a>
          )}
        </div>
      </nav>
    )}
    <button class="back-to-top" type="button" data-back-to-top aria-label="阅读进度，回到顶部">
      <Icon name="lucide:arrow-up" aria-hidden="true" />
      <span data-read-progress-label>0%</span>
    </button>
    <script id="recent-post-data" type="application/json" set:html={JSON.stringify({
      title: post.title,
      url: post.url,
      series: post.series,
      meta: `${post.series} · ${formatDate(post.date)} · 约 ${post.minutes} 分钟阅读`
    })}></script>
    <script is:inline data-code-block-mode={codeBlockMode}>
      const recentPostData = document.querySelector("#recent-post-data");
      try {
        const key = "yunbo-recent-posts";
        const post = JSON.parse(recentPostData.textContent);
        const posts = JSON.parse(localStorage.getItem(key) || "[]").filter((item) => item.url !== post.url);
        localStorage.setItem(key, JSON.stringify([post, ...posts].slice(0, 5)));
      } catch {}

      const articleBody = document.querySelector(".article-body");
      const toc = document.querySelector("[data-article-toc]");
      const tocNav = toc?.querySelector("nav");
      const tocToggle = document.querySelector("[data-toc-toggle]");
      const backToTop = document.querySelector("[data-back-to-top]");
      const readProgressLabel = document.querySelector("[data-read-progress-label]");
      const codeBlockMode = document.currentScript?.dataset.codeBlockMode || "legacy";
      const headings = [...articleBody.querySelectorAll("h2, h3, h4")].filter((heading) => heading.id && heading.textContent.trim());

      const updateBackToTop = () => {
        backToTop?.classList.toggle("is-visible", window.scrollY > 520);
        const start = articleBody.offsetTop;
        const end = Math.max(start + articleBody.offsetHeight - window.innerHeight, start + 1);
        const progress = Math.min(1, Math.max(0, (window.scrollY - start) / (end - start)));
        backToTop?.style.setProperty("--read-progress", `${Math.round(progress * 360)}deg`);
        if (readProgressLabel) readProgressLabel.textContent = `${Math.round(progress * 100)}%`;
      };

      backToTop?.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
      window.addEventListener("scroll", updateBackToTop, { passive: true });
      updateBackToTop();

      if (headings.length > 0 && toc && tocNav) {
        toc.hidden = false;
        if (tocToggle) tocToggle.hidden = false;
        tocNav.innerHTML = headings.map((heading) => `
          <a class="level-${heading.tagName.toLowerCase()}" href="#${heading.id}">${heading.textContent.trim()}</a>
        `).join("");

        const tocLinks = [...tocNav.querySelectorAll("a")];
        const updateActiveToc = () => {
          const activeIndex = Math.max(0, headings.findLastIndex((heading) => heading.getBoundingClientRect().top <= 120));
          tocLinks.forEach((link, index) => {
            link.classList.toggle("is-active", index === activeIndex);
            if (index === activeIndex) {
              link.setAttribute("aria-current", "location");
            } else {
              link.removeAttribute("aria-current");
            }
          });
        };

        window.addEventListener("scroll", updateActiveToc, { passive: true });
        updateActiveToc();

        tocToggle?.addEventListener("click", () => {
          const isOpen = toc.classList.toggle("is-open");
          tocToggle.setAttribute("aria-expanded", String(isOpen));
        });

        tocLinks.forEach((link) => {
          link.addEventListener("click", () => {
            toc.classList.remove("is-open");
            tocToggle?.setAttribute("aria-expanded", "false");
          });
        });
      }

      const formatLanguage = (language) => {
        const value = String(language || "code").trim();
        if (!value || value === "undefined") return "CODE";
        return value.length > 18 ? value.slice(0, 18).toUpperCase() : value.toUpperCase();
      };

      const copyCode = async (text) => {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
          return;
        }

        const textarea = document.createElement("textarea");
        textarea.value = text;
        textarea.setAttribute("readonly", "");
        textarea.style.position = "fixed";
        textarea.style.inset = "0 auto auto 0";
        textarea.style.opacity = "0";
        document.body.append(textarea);
        textarea.select();
        document.execCommand("copy");
        textarea.remove();
      };

      if (codeBlockMode === "legacy") articleBody.querySelectorAll("pre").forEach((pre) => {
        if (pre.closest(".code-frame")) return;

        const code = pre.querySelector("code");
        const classLanguage = code?.className.match(/language-([a-z0-9_-]+)/i)?.[1];
        const language = formatLanguage(pre.dataset.language || classLanguage);
        const codeText = pre.innerText.replace(/\n$/, "");
        const lineCount = pre.querySelectorAll(".line").length || codeText.split("\n").length;

        const frame = document.createElement("figure");
        frame.className = "code-frame";
        if (lineCount > 15) frame.classList.add("is-long", "is-collapsed");

        const header = document.createElement("figcaption");
        header.className = "code-frame-head";

        const title = document.createElement("div");
        title.className = "code-frame-title";

        const dots = document.createElement("span");
        dots.className = "code-window-dots";
        dots.setAttribute("aria-hidden", "true");
        dots.innerHTML = "<span></span><span></span><span></span>";

        const label = document.createElement("span");
        label.className = "code-language";
        label.textContent = language;

        const meta = document.createElement("span");
        meta.className = "code-lines";
        meta.textContent = `${lineCount} 行`;

        const copyButton = document.createElement("button");
        copyButton.className = "code-copy";
        copyButton.type = "button";
        copyButton.textContent = "复制";
        copyButton.setAttribute("aria-label", "复制代码");

        title.append(dots, label, meta);
        header.append(title, copyButton);

        pre.before(frame);
        frame.append(header, pre);

        copyButton.addEventListener("click", async () => {
          const originalText = copyButton.textContent;
          try {
            await copyCode(codeText);
            copyButton.textContent = "已复制";
            copyButton.classList.add("is-copied");
          } catch {
            copyButton.textContent = "复制失败";
          }

          window.setTimeout(() => {
            copyButton.textContent = originalText;
            copyButton.classList.remove("is-copied");
          }, 1600);
        });

        if (lineCount > 15) {
          const footer = document.createElement("div");
          footer.className = "code-frame-foot";

          const expandButton = document.createElement("button");
          expandButton.className = "code-expand";
          expandButton.type = "button";
          expandButton.textContent = "展开全部";

          expandButton.addEventListener("click", () => {
            const collapsed = frame.classList.toggle("is-collapsed");
            expandButton.textContent = collapsed ? "展开全部" : "收起代码";
          });

          footer.append(expandButton);
          frame.append(footer);
        }
      });
    </script>
  </article>
</BaseLayout>
