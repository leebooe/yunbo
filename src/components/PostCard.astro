---
import { formatDate, getBlogFilterUrl, type Post } from "@/lib/posts";

type Props = {
  post: Post;
};

const { post } = Astro.props;
---

<article class="post-card" data-pagefind-ignore data-post-slug={post.slug}>
  <div class={`post-card-media${post.coverImage ? "" : " is-placeholder"}`}>
    <a href={post.url} aria-label={post.title}>
      {post.coverImage ? (
        <img src={post.coverImage} alt={post.coverAlt || ""} loading="lazy" />
      ) : (
        <div aria-hidden="true">
          <span>{post.series}</span>
          <b>{post.title.slice(0, 2)}</b>
        </div>
      )}
    </a>
  </div>
  <a class="post-card-series" href={getBlogFilterUrl({ series: post.series })}>{post.series}</a>
  <div>
    <div class="meta">
      <span>{formatDate(post.date)}</span>
      <span>约 {post.minutes} 分钟阅读</span>
    </div>
    <h2><a href={post.url}>{post.title}</a></h2>
    <p>{post.description}</p>
  </div>
  <div class="tag-list" aria-label="标签">
    {post.tags.slice(0, 3).map((tag) => <a class="tag" href={getBlogFilterUrl({ tag })}>{tag}</a>)}
  </div>
</article>
